<Page
    x:Class="FitProjectWin.Views.ProgressPhotosPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BackgroundBrush}">

    <Grid RowDefinitions="Auto,Auto,*">
        <Grid Grid.Row="0" Padding="24,16,24,8" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Click="Back_Click" Background="Transparent" BorderThickness="0"
                    HorizontalAlignment="Left" Padding="0">
                <FontIcon Glyph="&#xE72B;" FontSize="16" Foreground="{StaticResource TextPrimaryBrush}" />
            </Button>
            <TextBlock Grid.Column="1" Text="Progress Photos" Style="{StaticResource HeadlineStyle}"
                       HorizontalAlignment="Center" />
            <Button Grid.Column="2" Click="AddPhoto_Click" Background="Transparent" BorderThickness="0"
                    ToolTipService.ToolTip="Add progress photo">
                <FontIcon Glyph="&#xE710;" FontSize="16" Foreground="{StaticResource AccentBrush}" />
            </Button>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Padding="24,0,24,12">
            <Button x:Name="SessionsTabBtn" Content="Sessions" Click="Tab_Click" Tag="sessions" MinWidth="100" />
            <Button x:Name="CompareTabBtn" Content="Compare" Click="Tab_Click" Tag="compare" MinWidth="100" />
        </StackPanel>

        <ScrollViewer Grid.Row="2" Padding="24,0,24,24">
            <StackPanel Spacing="16">
                <TextBlock x:Name="EmptyText"
                           Text="Take front, side, and back photos to track your transformation over time."
                           Style="{StaticResource CaptionStyle}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Visibility="Collapsed"
                           Margin="0,40,0,0" />

                <StackPanel x:Name="SessionsPanel" Spacing="16" />
                <StackPanel x:Name="ComparePanel" Spacing="16" Visibility="Collapsed" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>