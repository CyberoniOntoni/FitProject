<Page
    x:Class="FitProjectWin.Views.ProgressPhotosPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BackgroundBrush}">

    <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0" Padding="24,16,24,8" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Click="Back_Click" Background="Transparent" BorderThickness="0"
                    HorizontalAlignment="Left" Padding="0">
                <FontIcon Glyph="&#xE72B;" FontSize="16" Foreground="{StaticResource TextPrimaryBrush}" />
            </Button>
            <TextBlock Grid.Column="1" Text="Progress Photos" Style="{StaticResource HeadlineStyle}"
                       HorizontalAlignment="Center" />
        </Grid>

        <ScrollViewer Grid.Row="1" Padding="24,8,24,24">
            <StackPanel x:Name="ContentPanel" Spacing="16">
                <TextBlock x:Name="EmptyText"
                           Text="Take front, side, and back photos on FitPros.io to track your transformation over time. They sync here automatically."
                           Style="{StaticResource CaptionStyle}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Visibility="Collapsed"
                           Margin="0,40,0,0" />
                <StackPanel x:Name="SessionsList" Spacing="16" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>