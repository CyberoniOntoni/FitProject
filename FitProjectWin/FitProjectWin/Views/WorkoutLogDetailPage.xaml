<Page
    x:Class="FitProjectWin.Views.WorkoutLogDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BackgroundBrush}">

    <Grid Padding="24,16,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Button Content="← Back" Click="Back_Click" HorizontalAlignment="Left"
                Background="Transparent" Foreground="{StaticResource AccentBrush}" />
        <ScrollViewer Grid.Row="1" Margin="0,12,0,0">
            <StackPanel x:Name="DetailPanel" Spacing="12" />
        </ScrollViewer>
    </Grid>
</Page>