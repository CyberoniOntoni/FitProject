<Page
    x:Class="FitProjectWin.Views.ProgramsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Programs" Style="{StaticResource HeadlineStyle}" Margin="24,16,24,8" />

        <ScrollViewer Grid.Row="1" Padding="24,0,24,24">
            <StackPanel Spacing="12" x:Name="ProgramsList" />
        </ScrollViewer>
    </Grid>
</Page>