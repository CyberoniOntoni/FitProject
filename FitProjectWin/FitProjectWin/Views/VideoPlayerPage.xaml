<Page
    x:Class="FitProjectWin.Views.VideoPlayerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BackgroundBrush}">

    <Grid RowDefinitions="Auto,*" Padding="16">
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Button x:Name="CloseButton" Content="✕" Click="Close_Click"
                    HorizontalAlignment="Left" Width="40" Height="40"
                    Background="{StaticResource SurfaceBrush}" />
            <StackPanel HorizontalAlignment="Center" Spacing="2" Margin="48,0">
                <TextBlock x:Name="TitleText" Style="{StaticResource SectionTitleStyle}"
                           TextAlignment="Center" TextWrapping="Wrap" />
                <TextBlock Text="Exercise demonstration" Style="{StaticResource CaptionStyle}"
                           TextAlignment="Center" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" CornerRadius="12" Background="Black"
                BorderBrush="#20FFFFFF" BorderThickness="1">
            <Grid>
                <WebView2 x:Name="VideoWebView" />
                <ProgressRing x:Name="LoadingRing" IsActive="True" Width="48" Height="48"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Foreground="{StaticResource AccentBrush}" />
            </Grid>
        </Border>
    </Grid>
</Page>