<Page
    x:Class="FitProjectWin.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BackgroundBrush}">

    <ScrollViewer Padding="24,16,24,24">
        <StackPanel Spacing="20">
            <TextBlock Text="Profile" Style="{StaticResource HeadlineStyle}" />

            <StackPanel HorizontalAlignment="Center" Spacing="8">
                <Border Width="80" Height="80" CornerRadius="40"
                        Background="{StaticResource AccentGradientBrush}">
                    <TextBlock Text="{x:Bind ViewModel.Auth.CurrentUser.Initials, Mode=OneWay}"
                               FontSize="28" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="{x:Bind ViewModel.Auth.CurrentUser.DisplayName, Mode=OneWay}"
                           Style="{StaticResource SectionTitleStyle}" HorizontalAlignment="Center" />
                <TextBlock Text="{x:Bind ViewModel.Auth.CurrentUser.Email, Mode=OneWay}"
                           Style="{StaticResource CaptionStyle}" HorizontalAlignment="Center" />
            </StackPanel>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="4">
                    <TextBlock Text="FitPros.io Sync" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Style="{StaticResource CaptionStyle}">
                        <Run Text="Last synced " />
                        <Run Text="{x:Bind ViewModel.Data.LastSyncDate, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
            </Border>

            <TextBlock Text="Settings" Style="{StaticResource SectionTitleStyle}" />

            <Border Style="{StaticResource CardBorderStyle}" Padding="0">
                <Button Click="OpenSettings_Click" HorizontalAlignment="Stretch"
                        Background="Transparent" BorderThickness="0" Padding="16">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE713;" FontSize="18"
                                  Foreground="{StaticResource AccentBrush}"
                                  VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Unit Preferences" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Style="{StaticResource CaptionStyle}">
                                <Run Text="Weight, circumference &amp; more · " />
                                <Run Text="{x:Bind ViewModel.Data.UnitPreferences.Mass, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                        <FontIcon Grid.Column="2" Glyph="&#xE76C;" FontSize="14"
                                  Foreground="{StaticResource TextTertiaryBrush}"
                                  VerticalAlignment="Center" />
                    </Grid>
                </Button>
            </Border>

            <TextBlock Text="Track &amp; Record" Style="{StaticResource SectionTitleStyle}" />

            <Border Style="{StaticResource CardBorderStyle}" Padding="0">
                <Button Click="OpenHabits_Click" HorizontalAlignment="Stretch"
                        Background="Transparent" BorderThickness="0" Padding="16">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE73E;" FontSize="18"
                                  Foreground="{StaticResource AccentBrush}"
                                  VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Habits" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Style="{StaticResource CaptionStyle}">
                                <Run Text="Record daily habits · " />
                                <Run Text="{x:Bind ViewModel.Data.Habits.Count, Mode=OneWay}" />
                                <Run Text=" active" />
                            </TextBlock>
                        </StackPanel>
                        <FontIcon Grid.Column="2" Glyph="&#xE76C;" FontSize="14"
                                  Foreground="{StaticResource TextTertiaryBrush}"
                                  VerticalAlignment="Center" />
                    </Grid>
                </Button>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}" Padding="0">
                <Button Click="OpenProgressPhotos_Click" HorizontalAlignment="Stretch"
                        Background="Transparent" BorderThickness="0" Padding="16">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE722;" FontSize="18"
                                  Foreground="{StaticResource AccentBrush}"
                                  VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Progress Photos" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Style="{StaticResource CaptionStyle}">
                                <Run Text="Visual body transformation · " />
                                <Run Text="{x:Bind ViewModel.Data.ProgressSessions.Count, Mode=OneWay}" />
                                <Run Text=" sessions" />
                            </TextBlock>
                        </StackPanel>
                        <FontIcon Grid.Column="2" Glyph="&#xE76C;" FontSize="14"
                                  Foreground="{StaticResource TextTertiaryBrush}"
                                  VerticalAlignment="Center" />
                    </Grid>
                </Button>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}" Padding="0">
                <Button Click="OpenMeasurements_Click" HorizontalAlignment="Stretch"
                        Background="Transparent" BorderThickness="0" Padding="16">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE8AF;" FontSize="18"
                                  Foreground="{StaticResource AccentBrush}"
                                  VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Body Measurements" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Style="{StaticResource CaptionStyle}">
                                <Run Text="Weight, body comp &amp; more · " />
                                <Run Text="{x:Bind ViewModel.Data.Measurements.Count, Mode=OneWay}" />
                                <Run Text=" entries" />
                            </TextBlock>
                        </StackPanel>
                        <FontIcon Grid.Column="2" Glyph="&#xE76C;" FontSize="14"
                                  Foreground="{StaticResource TextTertiaryBrush}"
                                  VerticalAlignment="Center" />
                    </Grid>
                </Button>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}" Padding="0">
                <Button Click="OpenPersonalRecords_Click" HorizontalAlignment="Stretch"
                        Background="Transparent" BorderThickness="0" Padding="16">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE734;" FontSize="18"
                                  Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Personal Records" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Style="{StaticResource CaptionStyle}">
                                <Run Text="{x:Bind ViewModel.Data.PersonalRecords.Count, Mode=OneWay}" />
                                <Run Text=" records synced from workouts" />
                            </TextBlock>
                        </StackPanel>
                        <FontIcon Grid.Column="2" Glyph="&#xE76C;" FontSize="14"
                                  Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" />
                    </Grid>
                </Button>
            </Border>

            <Button Content="Refresh Data" Style="{StaticResource PrimaryButtonStyle}"
                    Command="{x:Bind ViewModel.RefreshCommand}" />

            <Button Content="Sign Out" HorizontalAlignment="Stretch"
                    Background="{StaticResource SurfaceHighlightBrush}"
                    Foreground="{StaticResource ErrorBrush}"
                    Command="{x:Bind ViewModel.SignOutCommand}" />
        </StackPanel>
    </ScrollViewer>
</Page>