<Page
    x:Class="FitProjectWin.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BackgroundBrush}">

    <ScrollViewer Padding="24,16,24,24">
        <StackPanel Spacing="20">
            <TextBlock Text="Profile" Style="{StaticResource HeadlineStyle}" />

            <StackPanel HorizontalAlignment="Center" Spacing="8">
                <Border Width="80" Height="80" CornerRadius="40"
                        Background="{StaticResource AccentGradientBrush}">
                    <TextBlock Text="{x:Bind ViewModel.Auth.CurrentUser.Initials, Mode=OneWay}"
                               FontSize="28" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="{x:Bind ViewModel.Auth.CurrentUser.DisplayName, Mode=OneWay}"
                           Style="{StaticResource SectionTitleStyle}" HorizontalAlignment="Center" />
                <TextBlock Text="{x:Bind ViewModel.Auth.CurrentUser.Email, Mode=OneWay}"
                           Style="{StaticResource CaptionStyle}" HorizontalAlignment="Center" />
            </StackPanel>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="4">
                    <TextBlock Text="FitPros.io Sync" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Style="{StaticResource CaptionStyle}">
                        <Run Text="Last synced " />
                        <Run Text="{x:Bind ViewModel.Data.LastSyncDate, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource CaptionStyle}">
                        <Run Text="{x:Bind ViewModel.Data.Habits.Count, Mode=OneWay}" />
                        <Run Text=" habits tracked" />
                    </TextBlock>
                    <TextBlock Style="{StaticResource CaptionStyle}">
                        <Run Text="{x:Bind ViewModel.Data.Measurements.Count, Mode=OneWay}" />
                        <Run Text=" measurements logged" />
                    </TextBlock>
                    <TextBlock Style="{StaticResource CaptionStyle}">
                        <Run Text="{x:Bind ViewModel.Data.PersonalRecords.Count, Mode=OneWay}" />
                        <Run Text=" personal records" />
                    </TextBlock>
                </StackPanel>
            </Border>

            <Button Content="Refresh Data" Style="{StaticResource PrimaryButtonStyle}"
                    Command="{x:Bind ViewModel.RefreshCommand}" />

            <Button Content="Sign Out" HorizontalAlignment="Stretch"
                    Background="{StaticResource SurfaceHighlightBrush}"
                    Foreground="{StaticResource ErrorBrush}"
                    Command="{x:Bind ViewModel.SignOutCommand}" />
        </StackPanel>
    </ScrollViewer>
</Page>