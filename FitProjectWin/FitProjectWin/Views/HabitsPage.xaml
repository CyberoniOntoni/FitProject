<Page
    x:Class="FitProjectWin.Views.HabitsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BackgroundBrush}">

    <ScrollViewer Padding="24,16,24,24">
        <StackPanel Spacing="16">
            <Grid>
                <Button Content="← Back" Click="Back_Click" HorizontalAlignment="Left"
                        Background="Transparent" Foreground="{StaticResource AccentBrush}" />
                <TextBlock Text="Habits" Style="{StaticResource HeadlineStyle}"
                           HorizontalAlignment="Center" />
            </Grid>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Today's Progress" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock x:Name="SummaryText" Style="{StaticResource CaptionStyle}" />
                    <ProgressBar x:Name="OverallProgress" Maximum="1"
                                 Foreground="{StaticResource AccentBrush}"
                                 Background="{StaticResource SurfaceHighlightBrush}" />
                </StackPanel>
            </Border>

            <StackPanel x:Name="HabitsList" Spacing="12" />
            <TextBlock x:Name="EmptyText" Text="No habits yet. Habits assigned on FitPros.io will sync here."
                       Style="{StaticResource CaptionStyle}" TextWrapping="Wrap"
                       Visibility="Collapsed" Margin="0,24,0,0" />
        </StackPanel>
    </ScrollViewer>
</Page>