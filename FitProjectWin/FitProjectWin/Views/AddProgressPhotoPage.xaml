<Page
    x:Class="FitProjectWin.Views.AddProgressPhotoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BackgroundBrush}">

    <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0" Padding="24,16,24,8" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Click="Back_Click" Background="Transparent" BorderThickness="0"
                    HorizontalAlignment="Left" Padding="0">
                <FontIcon Glyph="&#xE72B;" FontSize="16" Foreground="{StaticResource TextPrimaryBrush}" />
            </Button>
            <TextBlock Grid.Column="1" Text="Add Progress Photo" Style="{StaticResource HeadlineStyle}"
                       HorizontalAlignment="Center" />
        </Grid>

        <ScrollViewer Grid.Row="1" Padding="24,8,24,24">
            <StackPanel Spacing="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Date" Style="{StaticResource CaptionStyle}" />
                    <DatePicker x:Name="SessionDate" HorizontalAlignment="Stretch" />
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Text="Pose" Style="{StaticResource CaptionStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="FrontPoseBtn" Content="Front" Click="Pose_Click" Tag="front" />
                        <Button x:Name="SidePoseBtn" Content="Side" Click="Pose_Click" Tag="side" />
                        <Button x:Name="BackPoseBtn" Content="Back" Click="Pose_Click" Tag="back" />
                    </StackPanel>
                </StackPanel>

                <Border Style="{StaticResource CardBorderStyle}" MinHeight="280">
                    <StackPanel Spacing="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image x:Name="PreviewImage" Height="240" Stretch="Uniform" Visibility="Collapsed" />
                        <TextBlock x:Name="PlaceholderText" Text="Tap below to choose a photo"
                                   Style="{StaticResource CaptionStyle}" HorizontalAlignment="Center" />
                        <Button x:Name="PickPhotoBtn" Content="Choose Photo" Click="PickPhoto_Click"
                                Style="{StaticResource PrimaryButtonStyle}" />
                    </StackPanel>
                </Border>

                <StackPanel Spacing="8">
                    <TextBlock Text="Notes (optional)" Style="{StaticResource CaptionStyle}" />
                    <TextBox x:Name="NotesBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"
                             PlaceholderText="Add notes about your progress..." />
                </StackPanel>

                <TextBlock x:Name="StatusText" Style="{StaticResource CaptionStyle}" TextWrapping="Wrap" />

                <Button x:Name="SaveBtn" Content="Save Session" Click="Save_Click"
                        Style="{StaticResource PrimaryButtonStyle}" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>