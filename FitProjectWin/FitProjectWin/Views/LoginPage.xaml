<Page
    x:Class="FitProjectWin.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BackgroundBrush}">

    <Grid Padding="40">
        <StackPanel VerticalAlignment="Center" Spacing="24" MaxWidth="400">
            <StackPanel HorizontalAlignment="Center" Spacing="8">
                <FontIcon Glyph="&#xE7B3;" FontSize="48" Foreground="{StaticResource AccentBrush}" />
                <TextBlock Text="Fit Project" Style="{StaticResource HeadlineStyle}" HorizontalAlignment="Center" />
                <TextBlock Text="Science-backed training. Synced with FitPros."
                           Style="{StaticResource CaptionStyle}" TextAlignment="Center" />
            </StackPanel>

            <TextBox x:Name="EmailBox" PlaceholderText="Email"
                     Text="{x:Bind ViewModel.LoginEmail, Mode=TwoWay}"
                     Background="{StaticResource SurfaceBrush}"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     BorderBrush="#20FFFFFF" />

            <PasswordBox x:Name="PasswordBox" PlaceholderText="Password"
                         PasswordChanged="PasswordBox_PasswordChanged"
                         Background="{StaticResource SurfaceBrush}"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         BorderBrush="#20FFFFFF" />

            <TextBlock Text="{x:Bind ViewModel.Auth.ErrorMessage, Mode=OneWay}"
                       Foreground="{StaticResource ErrorBrush}"
                       Visibility="{x:Bind ViewModel.Auth.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToCollapsed}}"
                       Style="{StaticResource CaptionStyle}" />

            <Button Content="Sign In" Style="{StaticResource PrimaryButtonStyle}"
                    Command="{x:Bind ViewModel.SignInCommand}"
                    IsEnabled="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InvertBool}}" />

            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Width="32" Height="32" HorizontalAlignment="Center"
                          Foreground="{StaticResource AccentBrush}" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                <FontIcon Glyph="&#xE895;" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" />
                <TextBlock Text="Syncs seamlessly with FitPros.io"
                           Style="{StaticResource CaptionStyle}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>