<Page
    x:Class="FitProjectWin.Views.PersonalRecordsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource BackgroundBrush}">

    <ScrollViewer Padding="24,16,24,24">
        <StackPanel Spacing="16">
            <Grid>
                <Button Content="← Back" Click="Back_Click" HorizontalAlignment="Left"
                        Background="Transparent" Foreground="{StaticResource AccentBrush}" />
                <TextBlock Text="Personal Records" Style="{StaticResource HeadlineStyle}"
                           HorizontalAlignment="Center" />
            </Grid>
            <StackPanel x:Name="RecordsList" Spacing="8" />
            <TextBlock x:Name="EmptyText" Text="No personal records yet. PRs sync from FitPros.io after workouts."
                       Style="{StaticResource CaptionStyle}" TextWrapping="Wrap" Visibility="Collapsed" />
        </StackPanel>
    </ScrollViewer>
</Page>