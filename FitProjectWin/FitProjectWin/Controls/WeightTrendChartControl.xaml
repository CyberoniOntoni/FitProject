<UserControl
    x:Class="FitProjectWin.Controls.WeightTrendChartControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///Themes/Colors.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Spacing="14">
        <Grid>
            <TextBlock Text="Bodyweight Trend" Style="{StaticResource SectionTitleStyle}" />
            <TextBlock x:Name="ExploreHintText"
                       Text="Drag to explore"
                       Style="{StaticResource CaptionStyle}"
                       Foreground="{StaticResource TextTertiaryBrush}"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Top" />
        </Grid>

        <Border Background="{StaticResource SurfaceHighlightBrush}"
                Opacity="0.45"
                CornerRadius="12"
                Padding="14,12">
            <Grid>
                <StackPanel Spacing="2" VerticalAlignment="Bottom">
                    <TextBlock x:Name="SelectedValueText"
                               FontSize="28"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="SelectedUnitText"
                               Style="{StaticResource CaptionStyle}"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>

                <StackPanel HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Spacing="4">
                    <TextBlock x:Name="SelectedDateText"
                               Style="{StaticResource CaptionStyle}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Right"
                               TextAlignment="Right" />
                    <TextBlock x:Name="SelectedDeltaText"
                               FontSize="13"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Right"
                               Visibility="Collapsed" />
                </StackPanel>
            </Grid>
        </Border>

        <Canvas x:Name="ChartCanvas"
                Height="168"
                Background="Transparent"
                PointerPressed="ChartCanvas_PointerPressed"
                PointerMoved="ChartCanvas_PointerMoved" />
    </StackPanel>
</UserControl>