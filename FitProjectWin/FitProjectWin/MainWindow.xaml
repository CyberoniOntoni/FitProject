<Window
    x:Class="FitProjectWin.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:FitProjectWin.Views"
    Title="Fit Project">

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid x:Name="LoginPanel" Visibility="Collapsed">
            <views:LoginPage />
        </Grid>

        <Grid x:Name="MainPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Frame x:Name="ContentFrame" Grid.Row="0" />

            <Border Grid.Row="1" Background="{StaticResource SurfaceElevatedBrush}"
                    BorderBrush="#15FFFFFF" BorderThickness="0,1,0,0" Padding="0,8,0,12">
                <NavigationView x:Name="NavView"
                                IsBackButtonVisible="Collapsed"
                                IsSettingsVisible="False"
                                PaneDisplayMode="Bottom"
                                SelectionChanged="NavView_SelectionChanged">
                    <NavigationView.MenuItems>
                        <NavigationViewItem Content="Train" Tag="Train" Icon="Play" />
                        <NavigationViewItem Content="Programs" Tag="Programs" Icon="List" />
                        <NavigationViewItem Content="Learn" Tag="Learn" Icon="Bookmarks" />
                        <NavigationViewItem Content="History" Tag="History" Icon="Clock" />
                    </NavigationView.MenuItems>
                    <NavigationView.FooterMenuItems>
                        <NavigationViewItem Content="Profile" Tag="Profile" Icon="Contact" />
                    </NavigationView.FooterMenuItems>
                </NavigationView>
            </Border>
        </Grid>

        <Grid x:Name="WorkoutOverlay" Visibility="Collapsed" Background="#CC000000">
            <views:WorkoutSessionPage x:Name="WorkoutPage" />
        </Grid>
    </Grid>
</Window>