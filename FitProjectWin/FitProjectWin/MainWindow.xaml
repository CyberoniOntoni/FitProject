<Window
    x:Class="FitProjectWin.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:FitProjectWin.Views"
    Title="Fit Project">

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid x:Name="LoginPanel" Visibility="Collapsed">
            <views:LoginPage />
        </Grid>

        <Grid x:Name="MainPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Frame x:Name="ContentFrame" Grid.Row="0" />

            <Border Grid.Row="1" Background="{StaticResource SurfaceElevatedBrush}"
                    BorderBrush="#15FFFFFF" BorderThickness="0,1,0,0" Padding="8,8,8,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="NavTrain" Grid.Column="0" Click="NavButton_Click" Tag="Train"
                            Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch">
                        <StackPanel Spacing="2" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE768;" FontSize="18" />
                            <TextBlock Text="Train" FontSize="10" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavPrograms" Grid.Column="1" Click="NavButton_Click" Tag="Programs"
                            Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch">
                        <StackPanel Spacing="2" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE8FD;" FontSize="18" />
                            <TextBlock Text="Programs" FontSize="10" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavLearn" Grid.Column="2" Click="NavButton_Click" Tag="Learn"
                            Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch">
                        <StackPanel Spacing="2" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE82D;" FontSize="18" />
                            <TextBlock Text="Learn" FontSize="10" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavHistory" Grid.Column="3" Click="NavButton_Click" Tag="History"
                            Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch">
                        <StackPanel Spacing="2" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE81C;" FontSize="18" />
                            <TextBlock Text="History" FontSize="10" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavProfile" Grid.Column="4" Click="NavButton_Click" Tag="Profile"
                            Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch">
                        <StackPanel Spacing="2" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE77B;" FontSize="18" />
                            <TextBlock Text="Profile" FontSize="10" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="WorkoutOverlay" Visibility="Collapsed" Background="#CC000000">
            <views:WorkoutSessionPage x:Name="WorkoutPage" />
        </Grid>

        <Grid x:Name="VideoOverlay" Visibility="Collapsed" Background="#E6000000">
            <views:VideoPlayerPage x:Name="VideoPage" MaxWidth="720" HorizontalAlignment="Center" />
        </Grid>
    </Grid>
</Window>