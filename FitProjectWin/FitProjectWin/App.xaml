<Application
    x:Class="FitProjectWin.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="Themes/Colors.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <conv:NullToCollapsedConverter x:Key="NullToCollapsed" xmlns:conv="using:FitProjectWin.Converters" />
            <conv:InvertBoolConverter x:Key="InvertBool" xmlns:conv="using:FitProjectWin.Converters" />
            <conv:ProgressToPercentConverter x:Key="ProgressToPercent" xmlns:conv="using:FitProjectWin.Converters" />
            <conv:DoubleFormatConverter x:Key="DoubleFormat" xmlns:conv="using:FitProjectWin.Converters" />
            <conv:CountToVisibilityConverter x:Key="CountToVisible" xmlns:conv="using:FitProjectWin.Converters" />
        </ResourceDictionary>
    </Application.Resources>
</Application>