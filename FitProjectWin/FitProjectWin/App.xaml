<Application
    x:Class="FitProjectWin.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:FitProjectWin.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="Themes/Colors.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <conv:NullToCollapsedConverter x:Key="NullToCollapsed" />
            <conv:BoolToVisibleConverter x:Key="BoolToVisible" />
            <conv:InvertBoolConverter x:Key="InvertBool" />
            <conv:ProgressToPercentConverter x:Key="ProgressToPercent" />
            <conv:DoubleFormatConverter x:Key="DoubleFormat" />
            <conv:CountToVisibilityConverter x:Key="CountToVisible" />
        </ResourceDictionary>
    </Application.Resources>
</Application>